# ==========================================
# RECONIX - VARIAVEIS DE AMBIENTE
# ==========================================
# ATENCAO: Este arquivo contem valores de EXEMPLO.
# Copie para .env e altere os valores antes de usar em producao.

# PostgreSQL
POSTGRES_USER=reconix
POSTGRES_PASSWORD=SUA_SENHA_SEGURA_AQUI
POSTGRES_DB=reconix_db

# MongoDB
MONGO_USER=reconix
MONGO_PASSWORD=SUA_SENHA_SEGURA_AQUI

# Redis
REDIS_PASSWORD=SUA_SENHA_SEGURA_AQUI

# RabbitMQ
RABBITMQ_USER=reconix
RABBITMQ_PASSWORD=SUA_SENHA_SEGURA_AQUI

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=SUA_SENHA_SEGURA_AQUI

# MinIO
MINIO_ACCESS_KEY=reconix
MINIO_SECRET_KEY=SUA_SENHA_SEGURA_AQUI

# Eureka
EUREKA_USER=reconix
EUREKA_PASSWORD=SUA_SENHA_SEGURA_AQUI

# Config Server
CONFIG_USER=reconix
CONFIG_PASSWORD=SUA_SENHA_SEGURA_AQUI

# JWT
JWT_SECRET=SUA_CHAVE_SECRETA_AQUI

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=SUA_SENHA_SEGURA_AQUI